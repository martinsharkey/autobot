{
    "name": "autobot",
    "displayName": "AUTOBOT",
    "description": "Fully autonomous AI coding agent — self-healing, self-coding, self-enhancing",
    "version": "2.0.0",
    "publisher": "autobot-dev",
    "license": "MIT",
    "engines": {
        "vscode": "^1.85.0"
    },
    "categories": [
        "Chat",
        "Programming Languages",
        "Machine Learning"
    ],
    "keywords": [
        "ai",
        "agent",
        "autonomous",
        "coding",
        "llm",
        "self-healing"
    ],
    "activationEvents": [
        "onStartupFinished"
    ],
    "main": "./dist/extension.js",
    "contributes": {
        "commands": [
            {
                "command": "autobot.startChat",
                "title": "AUTOBOT: Start Chat",
                "category": "AUTOBOT"
            },
            {
                "command": "autobot.runTask",
                "title": "AUTOBOT: Run Autonomous Task...",
                "category": "AUTOBOT"
            },
            {
                "command": "autobot.stopAgent",
                "title": "AUTOBOT: Stop Agent",
                "category": "AUTOBOT"
            },
            {
                "command": "autobot.explainCode",
                "title": "AUTOBOT: Explain Selected Code",
                "category": "AUTOBOT"
            },
            {
                "command": "autobot.refactorCode",
                "title": "AUTOBOT: Refactor Selected Code",
                "category": "AUTOBOT"
            },
            {
                "command": "autobot.generateTests",
                "title": "AUTOBOT: Generate Tests",
                "category": "AUTOBOT"
            },
            {
                "command": "autobot.showMemory",
                "title": "AUTOBOT: Show Memory",
                "category": "AUTOBOT"
            },
            {
                "command": "autobot.showSkills",
                "title": "AUTOBOT: Show Skills",
                "category": "AUTOBOT"
            }
        ],
        "configuration": {
            "title": "AUTOBOT",
            "properties": {
                "autobot.gatewayUrl": {
                    "type": "string",
                    "default": "http://127.0.0.1:8001",
                    "description": "AUTOBOT Gateway URL"
                },
                "autobot.gatewayApiKey": {
                    "type": "string",
                    "default": "changeme",
                    "description": "Gateway API key"
                },
                "autobot.defaultMode": {
                    "type": "string",
                    "default": "coder",
                    "enum": [
                        "architect",
                        "coder",
                        "reflector",
                        "learner",
                        "evolver"
                    ]
                },
                "autobot.maxLoops": {
                    "type": "number",
                    "default": 50,
                    "description": "Max autonomous loops per task"
                },
                "autobot.autoStartGateway": {
                    "type": "boolean",
                    "default": true,
                    "description": "Auto-start Python gateway if not running"
                }
            }
        },
        "keybindings": [
            {
                "command": "autobot.startChat",
                "key": "ctrl+alt+a",
                "mac": "cmd+alt+a"
            },
            {
                "command": "autobot.explainCode",
                "key": "ctrl+alt+e",
                "mac": "cmd+alt+e"
            }
        ],
        "viewsContainers": {
            "activitybar": [
                {
                    "id": "autobot-sidebar",
                    "title": "AUTOBOT",
                    "icon": "$(rocket)"
                }
            ]
        },
        "views": {
            "autobot-sidebar": [
                {
                    "type": "webview",
                    "id": "autobot.chat",
                    "name": "Chat"
                },
                {
                    "id": "autobot.memory",
                    "name": "Memory"
                }
            ]
        }
    },
    "scripts": {
        "vscode:prepublish": "npm run compile",
        "compile": "tsc -p ./",
        "watch": "tsc -watch -p ./",
        "package": "vsce package"
    },
    "devDependencies": {
        "@types/node": "^20.0.0",
        "@types/vscode": "^1.85.0",
        "typescript": "^5.3.0"
    },
    "dependencies": {
        "@roo-code/types": "^1.115.0",
        "zod": "^4.4.3"
    }
}
